{
  "name": "chipratio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Poker chip calculator for perfect home game splits. Enter your set, get exact equal stacks. Free forever, no ads, no signup.",
  "license": "MIT",
  "homepage": "https://chipratio.pages.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/KarthikSubramanian07/ChipRatio.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "feel": "tsx scripts/feel-test.ts",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=chipratio"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
